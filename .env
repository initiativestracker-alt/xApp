# ════════════════════════════════════════════════════════════════════════════
# xapp-platform / .env
# All secrets and credentials. Edit this file only.
# Never commit to git — add .env to .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-in-production

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE

# IAM Role for Lambda execution
# 1. Go to AWS Console → IAM → Roles → Create Role
# 2. Trusted entity: Lambda
# 3. Attach policy: AWSLambdaBasicExecutionRole
# 4. Name it: xapp-lambda-role
# 5. Paste the ARN below
LAMBDA_EXEC_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID_HERE:role/xapp-lambda-role

# ── Gemini (Phase 3 — LLM-generated app code) ────────────────────────────────
GEMINI_API_KEY=AIzaSyBZTQVA_cyiu4W9xGSDAdNFHXj05f9XErk
GEMINI_MODEL=gemini-2.5-flash
